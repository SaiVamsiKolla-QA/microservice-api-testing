# .env.example — copy to .env.<ENV> and fill in real values before running tests
# framework/config.py loads .env.<ENV> based on the ENV variable at startup

# ── Environment ────────────────────────────────────────────────────────────────
# Selects which .env file to load (qa | stg | prod). Defaults to qa.
ENV=qa

# ── Service Config ─────────────────────────────────────────────────────────────
# Base URL for the target service. Required — framework raises on startup if missing.
BASE_URL=https://petstore.swagger.io/v2

# ── Auth ───────────────────────────────────────────────────────────────────────
# Bearer token injected as Authorization: Bearer <token>. Leave empty if not required.
BEARER_TOKEN=

# API key value injected via API_KEY_HEADER. Leave empty if not required.
API_KEY=

# Header name used to send the API key. Defaults to x-api-key.
API_KEY_HEADER=x-api-key

# ── HTTP ───────────────────────────────────────────────────────────────────────
# httpx client timeout in seconds applied to all requests.
REQUEST_TIMEOUT=10

# ── Logging ────────────────────────────────────────────────────────────────────
# Log level for the api_testing logger (DEBUG | INFO | WARNING | ERROR). Defaults to INFO.
LOG_LEVEL=INFO
